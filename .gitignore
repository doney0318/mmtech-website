# Laravel .gitignore

# Vendor directory
/vendor/

# Composer
composer.lock

# Environment
.env
.env.production
.env.local
.env.*.local

# Laravel
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
!storage/framework/cache/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!storage/logs/.gitkeep

# Testing
.phpunit.result.cache

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.backup

# Development tools
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Laravel Sail
.docker
docker-compose.override.yml

# Deployment
deploy.php
deploy.log
